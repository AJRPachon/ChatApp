<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude encrypted database -->
        <exclude domain="database" path="chat.db" />
        <exclude domain="database" path="chat.db-shm" />
        <exclude domain="database" path="chat.db-wal" />
        <!-- Exclude Supabase session tokens -->
        <exclude domain="sharedpref" path="supabase_session.xml" />
        <!-- Exclude SQLCipher passphrase -->
        <exclude domain="sharedpref" path="chatapp_db_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Same exclusions apply to device-to-device transfers -->
        <exclude domain="database" path="chat.db" />
        <exclude domain="database" path="chat.db-shm" />
        <exclude domain="database" path="chat.db-wal" />
        <exclude domain="sharedpref" path="supabase_session.xml" />
        <exclude domain="sharedpref" path="chatapp_db_prefs.xml" />
    </device-transfer>
</data-extraction-rules>